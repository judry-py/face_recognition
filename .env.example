# Copie ce fichier en `.env` puis adapte les valeurs selon tes besoins.
# Les clés ci-dessous surchargent les valeurs de `config.json`.

SURVEILLANCE_ADMIN_PASSWORD=
SURVEILLANCE_CAMERA_INDEX=0
SURVEILLANCE_DASHBOARD_HOST=127.0.0.1
SURVEILLANCE_DASHBOARD_PORT=5000
SURVEILLANCE_TELEGRAM_ENABLED=false
SURVEILLANCE_TELEGRAM_BOT_TOKEN=
SURVEILLANCE_TELEGRAM_CHAT_ID=
SURVEILLANCE_PERSON_DETECTION_ENABLED=true
SURVEILLANCE_PERSON_DETECTION_EVERY_N_FRAMES=4
SURVEILLANCE_REQUIRE_HUMAN_FOR_MOTION_ALERT=true
SURVEILLANCE_SURVEILLANCE_START_TIME=00:00
SURVEILLANCE_SURVEILLANCE_END_TIME=23:59
SURVEILLANCE_NIGHT_MODE_ENABLED=true
SURVEILLANCE_AUTO_START_CAMERA=true
